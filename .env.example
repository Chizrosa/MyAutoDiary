# Gemini APIキー（必須）
# 取得はこちらから: https://aistudio.google.com/
# ⚠️ 注意: このファイルではなく、コピーした「.env」に記入してください
GEMINI_API_KEY=your_api_key_here

# Discord連携（任意）
DISCORD_TOKEN=あなたのボットトークン
DISCORD_CHANNEL_ID=チャンネルID

# Location Settings
# 日本で使う場合は Tokyo / Asia/Tokyo を指定してください
CITY_NAME=Tokyo
TIMEZONE=Asia/Tokyo

# ログを保存するフォルダ（任意）
# 未設定の場合は、プロジェクト内の diaries フォルダに保存されます
SAVE_DIR=./diaries